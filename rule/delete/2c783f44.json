(maindata, torrent) => {
  if (torrent.downloaded > 0 && torrent.uploaded / torrent.downloaded > 3) return true;

  if (maindata.freeSpaceOnDisk >= 4 * 1024 * 1024 * 1024) return false;
  if (torrent.state === 'stalledDL' && torrent.progress === 0) return false;

  let min = Infinity, max = -1, maxHash = '', count = 0;
  for (const t of maindata.torrents) {
    if (t.state === 'stalledDL' && t.progress === 0) continue;
    count++;
    if (t.uploadSpeed < min) min = t.uploadSpeed;
    if (t.uploadSpeed > max) { max = t.uploadSpeed; maxHash = t.hash;
    }
  }

  return count > 1 && torrent.hash !== maxHash && torrent.uploadSpeed === min;
}
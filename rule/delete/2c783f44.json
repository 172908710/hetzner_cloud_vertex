(maindata, torrent) => {
  if (maindata.freeSpaceOnDisk >= 4 * 1024 * 1024 * 1024) {
    if (torrent.downloaded > 0 && torrent.uploaded / torrent.downloaded > 3 && torrent.uploadSpeed - 3 * torrent.downloadSpeed > 0) return true;
    return false;
  }
  if (torrent.state === 'stalledDL' && torrent.progress === 0) return false;
  const active = maindata.torrents.filter(t => !(t.state === 'stalledDL' && t.progress === 0));
  if (active.length <= 1) return true;
  const max = active.reduce((a, b) => a.uploadSpeed >= b.uploadSpeed ? a : b);
  if (torrent.hash === max.hash) return false;
  const min = Math.min(...active.map(t => t.uploadSpeed));
  if (torrent.uploadSpeed !== min) return false;
  const target = active.filter(t => t.uploadSpeed === min && t.hash !== max.hash)
    .sort((a, b) => (b.progress === 1) - (a.progress === 1) || b.uploaded - a.uploaded)[
    0
  ];
  return torrent.hash === target.hash;
}
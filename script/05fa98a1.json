async () => {
  const fs = require('fs');
  const path = require('path');
  const { execSync
  } = require('child_process');

  try {
    const logDirs = ['/app/vertex/logs', '/vertex/logs', '/app/vertex/data/logs'
    ];
    const keepDays = 5;
    const now = Date.now();
    let deleteCount = 0;

    for (const dir of logDirs) {
      if (fs.existsSync(dir)) {
        const files = fs.readdirSync(dir);
        for (const file of files) {
          const filePath = path.join(dir, file);
          const stats = fs.statSync(filePath);
          const daysOld = (now - stats.mtimeMs) / (1000 * 60 * 60 * 24);
          if (daysOld > keepDays && stats.isFile()) {
            fs.unlinkSync(filePath);
            deleteCount++;
          }
        }
      }
    }

    try { execSync('rm -rf /tmp/*'); } catch (e) {}

    logger.info('[空间保洁] 删除了 ' + deleteCount + ' 个过期日志。');
  } catch (err) {
    logger.error('[空间保洁] ' + err.message);
  }
}
